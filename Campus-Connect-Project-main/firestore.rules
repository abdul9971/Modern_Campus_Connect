
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }
    
    function isStudent() {
      return isSignedIn() && exists(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    // --------------------------------------------------------------------------------
    // User Profile Collections
    // --------------------------------------------------------------------------------

    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list: if false;
      allow create: if isOwner(adminId) && request.resource.data.id == adminId;
      allow update: if isOwner(adminId);
      allow delete: if false;
    }

    match /teachers/{teacherId} {
      allow get: if isOwner(teacherId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.id == teacherId;
      allow update: if (isOwner(teacherId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow get: if isOwner(studentId) || isAdmin() || isTeacher();
      allow list: if isAdmin() || isTeacher();
      allow create: if isAdmin() && request.resource.data.id == studentId;
      allow update: if (isOwner(studentId) || isAdmin());
      allow delete: if isAdmin();
    }
    
    // --------------------------------------------------------------------------------
    // Timetable Collections
    // --------------------------------------------------------------------------------

    match /timetableEntries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------------------------------
    // Application Data Collections
    // --------------------------------------------------------------------------------

    match /attendanceRecords/{recordId} {
      // A user can list records if they are signed in.
      // The security is enforced on a per-document basis by the `get` rule below.
      // A query will fail if it attempts to read documents the user doesn't have `get` permission for.
      allow list: if isSignedIn();
      
      // A user can get a specific record if they are the student in the record,
      // the teacher who took attendance, or an admin.
      allow get: if (isStudent() && resource.data.studentId == request.auth.uid)
                  || (isTeacher() && resource.data.teacherId == request.auth.uid)
                  || isAdmin();
                  
      // A teacher can create a record for their lecture.
      // A student can create a 'Pending' request for themselves.
      allow create: if (isTeacher() && request.resource.data.teacherId == request.auth.uid) ||
                      (isStudent() && request.resource.data.studentId == request.auth.uid && request.resource.data.status == 'Pending');
      
      // A teacher can update a record they created.
      allow update: if isTeacher() && resource.data.teacherId == request.auth.uid;
      
      // Deletes are not allowed.
      allow delete: if false;
    }
  }
}
